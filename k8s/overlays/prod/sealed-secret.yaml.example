# Sealed Secret for norppalive-service
#
# Generate the actual sealed-secret with kubeseal — the plaintext
# never leaves your terminal. The service runs on the marie cluster,
# so target marie's sealed-secrets controller specifically:
#
#   kubectl --context marie create secret generic norppalive-service-secrets \
#     --namespace=norppalive \
#     --from-literal=MASTODON_HOST='https://mastodon.example' \
#     --from-literal=MASTODON_TOKEN='<token>' \
#     --from-literal=BLUESKY_LOGIN='you.bsky.social' \
#     --from-literal=BLUESKY_HANDLE='you.bsky.social' \
#     --from-literal=BLUESKY_PASSWORD='<bsky-app-password>' \
#     --dry-run=client -o yaml \
#   | kubeseal \
#       --context=marie \
#       --controller-namespace=kube-system \
#       --controller-name=sealed-secrets-controller \
#       --format=yaml > sealed-secret.yaml
#
# The encrypted output is safe to commit. Only the cluster's
# sealed-secrets controller can decrypt it.
#
# Required keys (currently posted to):
#   MASTODON_HOST       - Mastodon instance URL (e.g. https://mastodon.social)
#   MASTODON_TOKEN      - Mastodon API token
#   BLUESKY_LOGIN       - Bluesky login (handle or email)
#   BLUESKY_HANDLE      - Bluesky handle (e.g. you.bsky.social)
#   BLUESKY_PASSWORD    - Bluesky app password (NOT main password)
#
# Optional — only needed if you flip "Twitter" into config.toml's
# `[output].services` list:
#   TWITTER_TOKEN
#   TWITTER_TOKEN_SECRET
#   TWITTER_CONSUMER_KEY
#   TWITTER_CONSUMER_SECRET
#
# Optional — override [bluesky].host (defaults to https://bsky.social):
#   BLUESKY_HOST
